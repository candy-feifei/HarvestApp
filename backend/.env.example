# 复制为 .env 后按需修改（不要将含密码的 .env 提交到 Git）
PORT=3000
NODE_ENV=development

# PostgreSQL 连接串（Prisma 使用）
# 本地示例：postgresql://postgres:postgres@localhost:5432/harvestapp?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/harvestapp?schema=public

# JWT（生产务必设置强随机 JWT_SECRET）
JWT_SECRET=please-change-in-production
JWT_EXPIRES_IN=7d

# 注册 false=关闭自助注册
AUTH_ALLOW_REGISTRATION=true

# 连续失败锁定
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15

# 密码重置 token 有效时间（分钟）
AUTH_RESET_TOKEN_MINUTES=60

# 团队邀请邮件中「设置密码」链接有效天数
AUTH_INVITE_TOKEN_DAYS=7

# 邮件里重置链接、前端根地址（无尾斜杠）
APP_PUBLIC_URL=http://127.0.0.1:5173

# 可选：SMTP，不配置时开发环境仅打印重置链接到日志
MAIL_FROM=noreply@example.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
